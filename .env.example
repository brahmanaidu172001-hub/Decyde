# ---------------------------------------------
# Decyde Environment Variables
# ---------------------------------------------
# Copy this file to `.env.local` and fill in the values.
# NEVER commit .env.local to version control.

# Required: your Anthropic API key (server-side only, never exposed to the browser)
ANTHROPIC_API_KEY=your_key_here

# Optional: model override. Defaults to claude-3-5-sonnet-20241022 in lib/prompt.ts.
# Recommended: claude-3-5-sonnet-20241022, claude-3-5-haiku-20241022, claude-3-opus-20240229
ANTHROPIC_MODEL=claude-3-5-sonnet-20241022

# Optional: request timeout in ms (defaults to 45000)
ANTHROPIC_TIMEOUT_MS=45000
